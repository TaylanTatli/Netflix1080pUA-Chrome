{
  "manifest_version": 3,
  "name": "Netflix 1080p UA",
  "description": "Forces Netflix to stream at 1080p.",
  "version": "2.0",
  "permissions": [
    "storage",
    "tabs",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "*://*.netflix.com/*",
    "*://assets.nflxext.com/*",
    "https://jnrbsn.github.io/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Netflix 1080p UA",
    "default_icons": {
      "48": "icon.svg",
      "96": "icon.svg",
      "128": "icon.svg"
    }
  },
  "icons": {
    "48": "icon.svg",
    "96": "icon.svg",
    "128": "icon.svg"
  },
  "background": {
    "service_worker": "background.js"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "netflix_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.netflix.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}